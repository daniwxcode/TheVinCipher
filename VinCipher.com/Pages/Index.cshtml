                        <div class="vehicle-card-hero">
                            <div class="vehicle-card-badge success" id="resultBadge"><svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8.5l3.5 3.5 6.5-8"/></svg> <span id="resultBadgeText">D&eacute;cod&eacute;</span></div>
                            <div class="vehicle-card-make" id="resultMake"></div>
                            <div class="vehicle-card-model" id="resultModel"></div>
                            <div class="vehicle-card-vin" id="resultVin"></div>
