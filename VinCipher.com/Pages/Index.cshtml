    <section class="playground section" id="playground">
        <div class="container">
            <div class="playground-box">
                <div style="text-align:center">
                    <span class="section-label">Tester l&#39;API</span>
                    <h2 class="section-title" style="margin-left:auto;margin-right:auto">Entrez un VIN, voyez la magie.</h2>
                    <p class="section-description" style="margin:0 auto">Saisissez un num&eacute;ro de ch&acirc;ssis (VIN) pour d&eacute;coder un v&eacute;hicule en temps r&eacute;el. Aucune cl&eacute; API requise pour tester.</p>
                </div>
                <form class="playground-form" id="decodeForm" onsubmit="return VinDecode.decode(event)">
                    <input class="playground-input" type="text" id="decodeVin" maxlength="17" minlength="17" placeholder="Ex : WBA3A5G59DNP26082" required spellcheck="false" autocomplete="off">
                    <button type="submit" class="btn btn-primary playground-btn" id="decodeBtn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        D&eacute;coder
                    </button>
                </form>
                <div class="playground-hint">
                    Essayez : <code onclick="VinDecode.fill('WBA3A5G59DNP26082')">WBA3A5G59DNP26082</code>
                    <code onclick="VinDecode.fill('1HGBH41JXMN109186')">1HGBH41JXMN109186</code>
                    <code onclick="VinDecode.fill('5YJSA1DG9DFP14705')">5YJSA1DG9DFP14705</code>
                </div>
                <div class="playground-quota" id="playgroundQuota"></div>
                <div class="decode-loading" id="decodeLoading">
                    <div class="decode-spinner"></div>
                    <p>D&eacute;codage de <span class="decode-vin-echo" id="loadingVin"></span>&hellip;</p>
                </div>
                <div class="decode-error" id="decodeError">
